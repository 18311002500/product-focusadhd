# Fastfile - Fastlane 自动化脚本

default_platform(:ios)

# 版本号递增
before_all do
  ensure_bundle_exec
  setup_ci if ENV['CI']
end

platform :ios do
  desc "生成 Xcode 项目"
  lane :generate_project do
    sh "xcodegen generate --project . --spec project.yml"
  end

  desc "运行测试"
  lane :test do
    generate_project
    scan(
      project: "FocusFlow.xcodeproj",
      scheme: "FocusFlow",
      destination: "platform=iOS Simulator,name=iPhone 15 Pro",
      clean: true,
      code_coverage: true
    )
  end

  desc "同步证书和 Provisioning Profile"
  lane :certificates do
    generate_project
    
    # 创建临时 keychain
    create_keychain(
      name: "build_keychain",
      password: ENV["KEYCHAIN_PASSWORD"] || "github-actions",
      default_keychain: true,
      unlock: true,
      timeout: 3600
    )
    
    # 获取证书（开发）
    get_certificates(
      development: true,
      output_path: "./fastlane/certs",
      keychain_path: "~/Library/Keychains/build_keychain-db",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || "github-actions"
    )
    
    # 获取证书（发布）
    get_certificates(
      development: false,
      output_path: "./fastlane/certs",
      keychain_path: "~/Library/Keychains/build_keychain-db",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || "github-actions"
    )
    
    # 获取开发 profile
    get_provisioning_profile(
      development: true,
      output_path: "./fastlane/profiles",
      filename: "Development_com.focusflow.app.mobileprovision"
    )
    
    # 获取发布 profile
    get_provisioning_profile(
      ad_hoc: false,
      app_store: true,
      output_path: "./fastlane/profiles",
      filename: "AppStore_com.focusflow.app.mobileprovision"
    )
  end

  desc "构建 Release 版本"
  lane :build_release do
    generate_project
    certificates
    
    # 更新版本号
    increment_version_number(
      version_number: ENV["VERSION_NUMBER"] || "1.0.0",
      xcodeproj: "FocusFlow.xcodeproj"
    )
    
    increment_build_number(
      build_number: ENV["BUILD_NUMBER"] || "1",
      xcodeproj: "FocusFlow.xcodeproj"
    )
    
    # 构建 Archive
    build_app(
      project: "FocusFlow.xcodeproj",
      scheme: "FocusFlow",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.focusflow.app" => "AppStore_com.focusflow.app"
        },
        teamID: ENV["TEAM_ID"]
      },
      output_directory: "./build",
      output_name: "FocusFlow.ipa",
      include_symbols: true,
      include_bitcode: false,
      xcargs: "-allowProvisioningUpdates"
    )
  end

  desc "上传到 TestFlight"
  lane :beta do
    build_release
    
    upload_to_testflight(
      ipa: "./build/FocusFlow.ipa",
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )
  end

  desc "上传到 App Store（提交审核）"
  lane :release do
    build_release
    
    # 上传到 App Store
    upload_to_app_store(
      ipa: "./build/FocusFlow.ipa",
      app_identifier: "com.focusflow.app",
      skip_metadata: true,  # 暂时跳过元数据更新
      skip_screenshots: true,  # 暂时跳过上传截图
      submit_for_review: false,  # 暂不自动提交审核
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "完整的发布流程"
  lane :deploy do
    ensure_git_status_clean
    release
    
    # 创建 Git tag
    version = get_version_number(xcodeproj: "FocusFlow.xcodeproj")
    build = get_build_number(xcodeproj: "FocusFlow.xcodeproj")
    
    add_git_tag(tag: "v#{version}-b#{build}")
    push_git_tags
  end

  desc "清理构建产物"
  lane :clean do
    sh "rm -rf ./build"
    sh "rm -rf ./fastlane/certs"
    sh "rm -rf ./fastlane/profiles"
    sh "rm -rf ~/Library/Developer/Xcode/Archives"
    sh "rm -rf FocusFlow.xcodeproj"
  end

  after_all do |lane|
    # 清理临时 keychain
    if lane == :build_release || lane == :release
      delete_keychain(name: "build_keychain") if is_ci
    end
  end

  error do |lane, exception|
    # 错误处理
    delete_keychain(name: "build_keychain") if is_ci
  end
end
